			)
			(layer "B.Paste"
				(type "Bottom Solder Paste")
			)
			(layer "B.SilkS"
				(type "Bottom Silk Screen")
			)
			(copper_finish "HAL lead-free")
			(dielectric_constraints no)
		)
		(pad_to_mask_clearance 0.1)
		(allow_soldermask_bridges_in_footprints no)
		(tenting front back)
		(grid_origin 75.1 100.625)
